@model GpuStore.Models.Order

@{
    ViewData["Title"] = $"Order {Model?.OrderNumber} - GPU Nexus";
}

<link rel="stylesheet" href="~/css/orders.css" />

<div class="order-details-container">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="order-header">
        <h1 class="order-title">Order Details</h1>
        <div class="order-status">
            <span class="status-label">Status:</span>
            <span class="status-badge @Model.Status.ToLower()">@Model.Status</span>
        </div>
    </div>

    <div class="order-info">
        <div class="info-section">
            <h3 class="section-heading">Order Information</h3>
            <div class="info-row">
                <span class="label">Order Number:</span>
                <span class="value">@Model.OrderNumber</span>
            </div>
            <div class="info-row">
                <span class="label">Order Date:</span>
                <span class="value">@Model.CreatedAt.ToString("MMMM dd, yyyy HH:mm")</span>
            </div>
            <div class="info-row">
                <span class="label">Shipping Address:</span>
                <span class="value">@Model.ShippingAddress</span>
            </div>
            @if (!string.IsNullOrEmpty(Model.Notes))
            {
                <div class="info-row">
                    <span class="label">Order Notes:</span>
                    <span class="value">@Model.Notes</span>
                </div>
            }
        </div>

        <div class="info-section">
            <h3 class="section-heading">Timeline</h3>
            <div class="timeline">
                <div class="timeline-item @(Model.Status != "Pending" ? "completed" : "")">
                    <span class="timeline-dot"></span>
                    <div class="timeline-content">
                        <span class="timeline-label">Ordered</span>
                        <span class="timeline-date">@Model.CreatedAt.ToString("MMM dd, yyyy")</span>
                    </div>
                </div>
                @if (Model.ShippedAt.HasValue)
                {
                    <div class="timeline-item completed">
                        <span class="timeline-dot"></span>
                        <div class="timeline-content">
                            <span class="timeline-label">Shipped</span>
                            <span class="timeline-date">@Model.ShippedAt?.ToString("MMM dd, yyyy")</span>
                        </div>
                    </div>
                }
                else if (Model.Status != "Pending" && Model.Status != "Cancelled")
                {
                    <div class="timeline-item pending">
                        <span class="timeline-dot"></span>
                        <div class="timeline-content">
                            <span class="timeline-label">Shipped</span>
                            <span class="timeline-date">Pending</span>
                        </div>
                    </div>
                }
                @if (Model.DeliveredAt.HasValue)
                {
                    <div class="timeline-item completed">
                        <span class="timeline-dot"></span>
                        <div class="timeline-content">
                            <span class="timeline-label">Delivered</span>
                            <span class="timeline-date">@Model.DeliveredAt?.ToString("MMM dd, yyyy")</span>
                        </div>
                    </div>
                }
                else if (Model.Status == "Shipped" || Model.Status == "Delivered")
                {
                    <div class="timeline-item pending">
                        <span class="timeline-dot"></span>
                        <div class="timeline-content">
                            <span class="timeline-label">Delivered</span>
                            <span class="timeline-date">In Transit</span>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="items-section">
        <h3 class="section-heading">Order Items</h3>
        <table class="items-table">
            <thead>
                <tr>
                    <th>Product</th>
                    <th>Unit Price</th>
                    <th>Quantity</th>
                    <th>Total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td class="product-name">@item.GpuName</td>
                        <td class="price">${item.UnitPrice:F2}</td>
                        <td class="quantity">@item.Quantity</td>
                        <td class="total">${item.TotalPrice:F2}</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="order-summary">
        <div class="summary-card">
            <div class="summary-row">
                <span class="label">Subtotal:</span>
                <span class="value">${Model.TotalAmount:F2}</span>
            </div>
            <div class="summary-row">
                <span class="label">Shipping:</span>
                <span class="value free">FREE</span>
            </div>
            <div class="summary-row">
                <span class="label">Tax:</span>
                <span class="value">$0.00</span>
            </div>
            <div class="summary-divider"></div>
            <div class="summary-row total-row">
                <span class="label">Total:</span>
                <span class="total-amount">${Model.TotalAmount:F2}</span>
            </div>
        </div>
    </div>

    <div class="order-actions">
        @if (Model.Status == "Pending")
        {
            <form method="post" asp-action="CancelOrder" class="action-form">
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to cancel this order?')">
                    Cancel Order
                </button>
            </form>
        }
        <a href="@Url.Action("MyOrders")" class="btn btn-outline-primary">Back to Orders</a>
        <a href="@Url.Action("Index", "Home")" class="btn btn-outline-primary">Continue Shopping</a>
    </div>
</div>

<style>
    .order-details-container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 30px 20px;
        background: var(--bg-base);
        min-height: calc(100vh - 200px);
    }

    .order-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 40px;
        padding-bottom: 20px;
        border-bottom: 2px solid var(--border);
    }

    .order-title {
        font-size: 32px;
        color: var(--text-primary);
        font-family: var(--font-display);
        font-weight: 600;
    }

    .order-status {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .status-label {
        color: var(--text-secondary);
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
    }

    .status-badge {
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        font-family: var(--font-mono);
        text-transform: uppercase;
    }

    .status-badge.pending {
        background: rgba(255, 107, 0, 0.15);
        color: var(--accent);
        border: 1px solid rgba(255, 107, 0, 0.3);
    }

    .status-badge.confirmed {
        background: rgba(77, 166, 255, 0.15);
        color: var(--blue);
        border: 1px solid rgba(77, 166, 255, 0.3);
    }

    .status-badge.shipped {
        background: rgba(0, 212, 106, 0.15);
        color: var(--green);
        border: 1px solid rgba(0, 212, 106, 0.3);
    }

    .status-badge.delivered {
        background: rgba(128, 90, 213, 0.15);
        color: #8a5ad5;
        border: 1px solid rgba(128, 90, 213, 0.3);
    }

    .status-badge.cancelled {
        background: rgba(255, 61, 61, 0.15);
        color: var(--red);
        border: 1px solid rgba(255, 61, 61, 0.3);
    }

    .order-info {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 30px;
        margin-bottom: 40px;
    }

    @@media (max-width: 768px) {
        .order-info {
            grid-template-columns: 1fr;
        }
    }

    .info-section {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 20px;
    }

    .section-heading {
        font-size: 16px;
        color: var(--text-primary);
        font-family: var(--font-display);
        font-weight: 600;
        margin-bottom: 15px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .section-heading::before {
        content: '';
        display: inline-block;
        width: 3px;
        height: 16px;
        background: var(--accent);
        border-radius: 2px;
    }

    .info-row {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        padding: 10px 0;
        border-bottom: 1px solid var(--border-dim);
        font-size: 13px;
    }

    .info-row:last-child {
        border-bottom: none;
    }

    .info-row .label {
        color: var(--text-muted);
        font-weight: 500;
    }

    .info-row .value {
        color: var(--text-primary);
        text-align: right;
        flex: 1;
        margin-left: 20px;
    }

    .timeline {
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    .timeline-item {
        display: flex;
        gap: 15px;
        align-items: flex-start;
    }

    .timeline-dot {
        display: inline-block;
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: var(--border);
        border: 2px solid var(--bg-card);
        flex-shrink: 0;
        margin-top: 4px;
    }

    .timeline-item.completed .timeline-dot {
        background: var(--green);
    }

    .timeline-item.pending .timeline-dot {
        background: var(--accent);
    }

    .timeline-content {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .timeline-label {
        color: var(--text-primary);
        font-weight: 600;
        font-size: 13px;
    }

    .timeline-date {
        color: var(--text-muted);
        font-size: 12px;
        font-family: var(--font-mono);
    }

    .items-section {
        margin-bottom: 40px;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 20px;
    }

    .items-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

    .items-table thead {
        border-bottom: 2px solid var(--border);
    }

    .items-table th {
        color: var(--text-muted);
        font-weight: 600;
        text-align: left;
        padding: 12px 0;
        text-transform: uppercase;
        font-family: var(--font-mono);
        font-size: 11px;
    }

    .items-table td {
        color: var(--text-primary);
        padding: 15px 0;
        border-bottom: 1px solid var(--border-dim);
    }

    .items-table tbody tr:last-child td {
        border-bottom: none;
    }

    .product-name {
        font-weight: 500;
    }

    .price, .total {
        text-align: right;
        font-family: var(--font-mono);
    }

    .quantity {
        text-align: center;
    }

    .order-summary {
        margin-bottom: 40px;
    }

    .summary-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 20px;
        max-width: 400px;
        margin-left: auto;
    }

    .summary-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 0;
        font-size: 13px;
    }

    .summary-row .label {
        color: var(--text-secondary);
        font-weight: 500;
    }

    .summary-row .value {
        color: var(--text-primary);
        font-family: var(--font-mono);
    }

    .summary-row .value.free {
        color: var(--green);
        font-weight: 600;
    }

    .summary-divider {
        height: 1px;
        background: var(--border);
        margin: 15px 0;
    }

    .total-row {
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
        padding: 15px 0;
    }

    .total-amount {
        font-size: 18px;
        font-weight: 700;
        color: var(--accent);
        font-family: var(--font-mono);
    }

    .order-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .action-form {
        display: flex;
    }

    .btn {
        padding: 12px 24px;
        border-radius: var(--radius-md);
        font-weight: 600;
        border: none;
        cursor: pointer;
        font-family: var(--font-body);
        font-size: 13px;
        transition: all var(--transition);
        text-decoration: none;
        display: inline-block;
        text-align: center;
    }

    .btn-danger {
        background: var(--red);
        color: white;
    }

    .btn-danger:hover {
        background: #ff5555;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(255, 61, 61, 0.3);
    }

    .btn-outline-primary {
        border: 1px solid var(--accent);
        color: var(--accent);
        background: transparent;
    }

    .btn-outline-primary:hover {
        background: var(--accent);
        color: #000;
    }

    .alert {
        background: rgba(255, 61, 61, 0.1);
        border: 1px solid var(--red);
        color: var(--red);
        padding: 12px 16px;
        border-radius: var(--radius-md);
        margin-bottom: 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .alert.alert-success {
        background: rgba(0, 212, 106, 0.1);
        border-color: var(--green);
        color: var(--green);
    }

    .btn-close {
        background: transparent;
        border: none;
        color: inherit;
        cursor: pointer;
        font-size: 20px;
        padding: 0;
        opacity: 0.7;
    }

    .btn-close:hover {
        opacity: 1;
    }
</style>
