@model GpuStore.Controllers.CheckoutViewModel

@{
    ViewData["Title"] = "Checkout - GPU Nexus";
}

<link rel="stylesheet" href="~/css/checkout.css" />

<div class="checkout-container">
    <div class="checkout-header">
        <h1 class="checkout-title">Order Checkout</h1>
        <p class="checkout-subtitle">Complete your purchase</p>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="checkout-content">
        <div class="checkout-form">
            <form method="post" asp-action="Checkout">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="form-section">
                    <h3 class="section-title">Shipping Information</h3>
                    <div class="form-group">
                        <label asp-for="ShippingAddress" class="form-label">Shipping Address</label>
                        <textarea asp-for="ShippingAddress" class="form-control" rows="3" placeholder="Street, City, State, ZIP, Country"></textarea>
                        <span asp-validation-for="ShippingAddress" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-section">
                    <h3 class="section-title">Additional Notes</h3>
                    <div class="form-group">
                        <label asp-for="Notes" class="form-label">Order Notes (Optional)</label>
                        <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Any special instructions..."></textarea>
                        <span asp-validation-for="Notes" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary btn-lg">Complete Purchase</button>
                    <a href="@Url.Action("Index", "Cart")" class="btn btn-outline-primary btn-lg">Back to Cart</a>
                </div>
            </form>
        </div>

        <div class="checkout-summary">
            <div class="summary-card">
                <h3 class="summary-title">Order Summary</h3>

                @if (Model?.Cart?.Items != null && Model.Cart.Items.Any())
                {
                    <div class="items-list">
                        @foreach (var item in Model.Cart.Items)
                        {
                            <div class="item-row">
                                <div class="item-info">
                                    <span class="item-name">@item.GPU.Name</span>
                                    <span class="item-qty">Qty: @item.Quantity</span>
                                </div>
                                <span class="item-price">$@((item.Quantity * item.Price).ToString("F2"))</span>
                            </div>
                        }
                    </div>

                    <div class="summary-divider"></div>

                    <div class="summary-row">
                        <span class="summary-label">Subtotal:</span>
                        <span class="summary-value">$@Model.TotalAmount.ToString("F2")</span>
                    </div>

                    <div class="summary-row">
                        <span class="summary-label">Shipping:</span>
                        <span class="summary-value free">FREE</span>
                    </div>

                    <div class="summary-row">
                        <span class="summary-label">Tax (Est.):</span>
                        <span class="summary-value">$0.00</span>
                    </div>

                    <div class="summary-row total-row">
                        <span class="summary-label">Total:</span>
                        <span class="total-amount">$@Model.TotalAmount.ToString("F2")</span>
                    </div>
                }
                else
                {
                    <p class="empty-message">Your cart is empty</p>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

<style>
    .checkout-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 30px 20px;
        background: var(--bg-base);
        min-height: calc(100vh - 200px);
    }

    .checkout-header {
        margin-bottom: 40px;
        text-align: center;
    }

    .checkout-title {
        font-size: 32px;
        color: var(--text-primary);
        font-family: var(--font-display);
        font-weight: 600;
        margin-bottom: 10px;
    }

    .checkout-subtitle {
        color: var(--text-secondary);
        font-size: 14px;
    }

    .checkout-content {
        display: grid;
        grid-template-columns: 1fr 350px;
        gap: 30px;
        margin-bottom: 20px;
    }

    @@media (max-width: 768px) {
        .checkout-content {
            grid-template-columns: 1fr;
        }
    }

    .checkout-form {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 30px;
    }

    .form-section {
        margin-bottom: 30px;
    }

    .form-section:last-of-type {
        margin-bottom: 0;
    }

    .section-title {
        font-size: 16px;
        color: var(--text-primary);
        font-family: var(--font-display);
        font-weight: 600;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .section-title::before {
        content: '';
        display: inline-block;
        width: 3px;
        height: 16px;
        background: var(--accent);
        border-radius: 2px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-label {
        display: block;
        color: var(--text-primary);
        margin-bottom: 8px;
        font-weight: 500;
        font-size: 13px;
    }

    .form-control {
        background: var(--bg-input);
        border: 1px solid var(--border);
        color: var(--text-primary);
        padding: 12px;
        border-radius: var(--radius-md);
        font-size: 14px;
        width: 100%;
        font-family: var(--font-body);
        transition: all var(--transition);
        resize: vertical;
    }

    .form-control:focus {
        border-color: var(--accent);
        box-shadow: 0 0 10px var(--accent-glow);
        outline: none;
    }

    .form-actions {
        display: flex;
        gap: 10px;
        margin-top: 30px;
    }

    .btn {
        padding: 12px 24px;
        border-radius: var(--radius-md);
        font-weight: 600;
        border: none;
        cursor: pointer;
        font-family: var(--font-body);
        font-size: 14px;
        transition: all var(--transition);
        text-decoration: none;
        display: inline-block;
        text-align: center;
    }

    .btn-primary {
        background: var(--accent);
        color: #000;
        flex: 1;
    }

    .btn-primary:hover {
        background: var(--accent-hover);
        transform: translateY(-2px);
        box-shadow: 0 4px 12px var(--accent-glow);
    }

    .btn-outline-primary {
        border: 1px solid var(--accent);
        color: var(--accent);
        background: transparent;
        flex: 1;
    }

    .btn-outline-primary:hover {
        background: var(--accent);
        color: #000;
    }

    .btn-lg {
        padding: 12px 24px;
    }

    .checkout-summary {
        position: sticky;
        top: 100px;
        height: fit-content;
    }

    .summary-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 20px;
    }

    .summary-title {
        font-size: 16px;
        color: var(--text-primary);
        font-family: var(--font-display);
        font-weight: 600;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .summary-title::before {
        content: '';
        display: inline-block;
        width: 3px;
        height: 16px;
        background: var(--accent);
        border-radius: 2px;
    }

    .items-list {
        margin-bottom: 20px;
    }

    .item-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 0;
        border-bottom: 1px solid var(--border-dim);
        font-size: 13px;
    }

    .item-row:last-child {
        border-bottom: none;
    }

    .item-info {
        display: flex;
        flex-direction: column;
        gap: 4px;
        flex: 1;
    }

    .item-name {
        color: var(--text-primary);
        font-weight: 500;
    }

    .item-qty {
        color: var(--text-muted);
        font-size: 12px;
    }

    .item-price {
        color: var(--accent);
        font-weight: 600;
        white-space: nowrap;
        margin-left: 10px;
    }

    .summary-divider {
        height: 1px;
        background: var(--border);
        margin: 15px 0;
    }

    .summary-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 0;
        font-size: 13px;
        color: var(--text-secondary);
    }

    .summary-label {
        font-weight: 500;
    }

    .summary-value {
        color: var(--text-primary);
    }

    .summary-value.free {
        color: var(--green);
        font-weight: 600;
    }

    .total-row {
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
        padding: 15px 0;
        margin: 15px 0;
    }

    .total-amount {
        font-size: 18px;
        font-weight: 700;
        color: var(--accent);
        font-family: var(--font-mono);
    }

    .alert {
        background: rgba(255, 61, 61, 0.1);
        border: 1px solid var(--red);
        color: var(--red);
        padding: 12px 16px;
        border-radius: var(--radius-md);
        margin-bottom: 20px;
    }

    .text-danger {
        color: var(--red);
        font-size: 12px;
        display: block;
        margin-top: 4px;
    }

    .empty-message {
        color: var(--text-muted);
        text-align: center;
        padding: 20px;
    }
</style>
