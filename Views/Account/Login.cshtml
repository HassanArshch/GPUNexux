@model GpuStore.Controllers.LoginViewModel

@{
    ViewData["Title"] = "Sign In - GPU Nexus";
}

<div class="auth-container">
    <div class="auth-card">
        <h1 class="auth-title">Sign In to GPU Nexus</h1>
        <p class="auth-subtitle">Enter your credentials to access your account</p>

        <form method="post" asp-action="Login" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="form-group">
                <label asp-for="Email" class="form-label">Email Address</label>
                <input asp-for="Email" type="email" class="form-control" placeholder="your@email.com" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password" class="form-label">Password</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="Enter your password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="form-check">
                <input asp-for="RememberMe" type="checkbox" class="form-check-input" id="rememberMe" />
                <label class="form-check-label" for="rememberMe">Remember me</label>
            </div>

            <button type="submit" class="btn  btn-primary btn-lg w-100">Sign In</button>
        </form>

        <div class="auth-divider">
            <span>Don't have an account?</span>
        </div>

        <a href="@Url.Action("Register")" class="btn container btn-outline-primary btn-lg w-100">Create Account</a>

        <p class="auth-footer">
            Demo Credentials:<br>
            Email: admin@gmail.com<br>
            Password: Admin@123456
        </p>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

<style>
    .auth-container {
        min-height: calc(100vh - 200px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 20px;
        background: var(--bg-base);
    }

    .auth-card {
        background: var(--bg-card);
        border: 1px solid var(--accent);
        border-radius: var(--radius-lg);
        padding: 40px;
        width: 100%;
        max-width: 400px;
        box-shadow: 0 0 20px var(--accent-glow);
    }

    .auth-title {
        color: var(--accent);
        font-size: 24px;
        margin-bottom: 10px;
        text-align: center;
        font-family: var(--font-display);
        font-weight: 600;
    }

    .container {
        display: flex;
        justify-content: center; /* Centers horizontally */
        align-items: center; /* Centers vertically */
        
    }

    .auth-subtitle {
        color: var(--text-secondary);
        text-align: center;
        margin-bottom: 30px;
        font-size: 14px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-label {
        display: block;
        color: var(--text-primary);
        margin-bottom: 8px;
        font-weight: 500;
        font-size: 13px;
    }

    .form-control {
        background: var(--bg-input);
        border: 1px solid var(--border);
        color: var(--text-primary);
        padding: 12px;
        border-radius: var(--radius-md);
        font-size: 14px;
        width: 100%;
        font-family: var(--font-body);
        transition: all var(--transition);
    }

    .form-control:focus {
        background: var(--bg-input);
        border-color: var(--accent);
        color: var(--text-primary);
        box-shadow: 0 0 10px var(--accent-glow);
        outline: none;
    }

    .form-check {
        margin-bottom: 20px;
        color: var(--text-primary);
        font-size: 14px;
    }

    .form-check-input {
        background: var(--bg-input);
        border: 1px solid var(--border);
        cursor: pointer;
        accent-color: var(--accent);
    }

    .form-check-label {
        cursor: pointer;
        margin-left: 8px;
    }

    .btn {
        padding: 12px;
        border-radius: var(--radius-md);
        font-weight: 600;
        transition: all var(--transition);
        border: none;
        cursor: pointer;
        font-family: var(--font-body);
        font-size: 14px;
        width: 100%;
        justify-content: center;
    }

    .btn-primary {
        background: var(--accent);
        color: #000;
        margin-bottom: 20px;
    }

    .btn-primary:hover {
        background: var(--accent-hover);
        transform: translateY(-2px);
        box-shadow: 0 4px 12px var(--accent-glow);
    }

    .btn-outline-primary {
        border: 2px solid var(--accent);
        color: var(--accent);
        background: transparent;
    }

    .btn-outline-primary:hover {
        background: var(--accent);
        color: #000;
    }

    .auth-divider {
        text-align: center;
        color: var(--text-secondary);
        margin: 20px 0;
        font-size: 12px;
    }

    .auth-footer {
        text-align: center;
        color: var(--text-muted);
        font-size: 12px;
        margin-top: 20px;
        padding-top: 20px;
        border-top: 1px solid var(--border);
        font-family: var(--font-mono);
        line-height: 1.8;
    }

    .text-danger {
        color: var(--red);
        font-size: 12px;
        display: block;
        margin-top: 4px;
    }

    .alert {
        background: rgba(255, 61, 61, 0.1);
        border: 1px solid var(--red);
        color: var(--red);
        padding: 12px;
        border-radius: var(--radius-md);
        margin-bottom: 20px;
    }

    .w-100 {
        width: 100%;
    }
</style>
