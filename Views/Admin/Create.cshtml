@model GPU
@{
    ViewData["Title"] = "Add New GPU";
}

<div class="admin-layout">
    <h1 class="admin-page-title">Add New GPU</h1>
    <p class="admin-subtitle">NEW PRODUCT ENTRY · INVENTORY MANAGEMENT</p>

    <div style="margin-bottom:16px">
        <a href="/Admin" class="admin-btn btn-secondary">← Back to Inventory</a>
    </div>

    <div class="form-card">
        <div class="form-card-header">⬡ GPU Specifications</div>
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="form-body">

                <div class="form-grid">
                    <!-- Name -->
                    <div class="form-group full">
                        <label class="form-label" asp-for="Name">Product Name *</label>
                        <input asp-for="Name" class="form-control" placeholder="e.g. GeForce RTX 5090" />
                        <span asp-validation-for="Name" class="validation-msg"></span>
                    </div>

                    <!-- Brand -->
                    <div class="form-group">
                        <label class="form-label" asp-for="Brand">Brand *</label>
                        <select asp-for="Brand" class="form-control">
                            <option value="">Select Brand</option>
                            <option value="NVIDIA">NVIDIA</option>
                            <option value="AMD">AMD</option>
                            <option value="Intel">Intel</option>
                        </select>
                        <span asp-validation-for="Brand" class="validation-msg"></span>
                    </div>

                    <!-- Architecture -->
                    <div class="form-group">
                        <label class="form-label" asp-for="Architecture">Architecture *</label>
                        <input asp-for="Architecture" class="form-control" placeholder="e.g. Ada Lovelace, RDNA 4" />
                        <span asp-validation-for="Architecture" class="validation-msg"></span>
                    </div>

                    <!-- Chip -->
                    <div class="form-group">
                        <label class="form-label" asp-for="ChipName">Chip Name *</label>
                        <input asp-for="ChipName" class="form-control" placeholder="e.g. AD102, Navi 31" />
                        <span asp-validation-for="ChipName" class="validation-msg"></span>
                    </div>

                    <!-- VRAM GB -->
                    <div class="form-group">
                        <label class="form-label" asp-for="VramGB">VRAM (GB)</label>
                        <input asp-for="VramGB" type="number" class="form-control" placeholder="24" min="1" max="96" />
                    </div>

                    <!-- VRAM Type -->
                    <div class="form-group">
                        <label class="form-label" asp-for="VramType">VRAM Type</label>
                        <select asp-for="VramType" class="form-control">
                            <option value="GDDR6">GDDR6</option>
                            <option value="GDDR6X">GDDR6X</option>
                            <option value="GDDR7">GDDR7</option>
                            <option value="HBM2e">HBM2e</option>
                            <option value="HBM3">HBM3</option>
                        </select>
                    </div>

                    <!-- Memory Bus -->
                    <div class="form-group">
                        <label class="form-label" asp-for="MemoryBusWidth">Memory Bus (bit)</label>
                        <select asp-for="MemoryBusWidth" class="form-control">
                            <option value="64">64-bit</option>
                            <option value="96">96-bit</option>
                            <option value="128">128-bit</option>
                            <option value="192">192-bit</option>
                            <option value="256">256-bit</option>
                            <option value="320">320-bit</option>
                            <option value="384">384-bit</option>
                        </select>
                    </div>

                    <!-- Core Count -->
                    <div class="form-group">
                        <label class="form-label" asp-for="CoreCount">Shader Count</label>
                        <input asp-for="CoreCount" type="number" class="form-control" placeholder="16384" />
                    </div>

                    <!-- Base Clock -->
                    <div class="form-group">
                        <label class="form-label" asp-for="BaseClock">Base Clock (MHz)</label>
                        <input asp-for="BaseClock" type="number" class="form-control" placeholder="2230" />
                    </div>

                    <!-- Boost Clock -->
                    <div class="form-group">
                        <label class="form-label" asp-for="BoostClock">Boost Clock (MHz)</label>
                        <input asp-for="BoostClock" type="number" class="form-control" placeholder="2520" />
                    </div>

                    <!-- TDP -->
                    <div class="form-group">
                        <label class="form-label" asp-for="TDP">TDP (Watts)</label>
                        <input asp-for="TDP" type="number" class="form-control" placeholder="450" />
                    </div>

                    <!-- PCIe Gen -->
                    <div class="form-group">
                        <label class="form-label" asp-for="PCIeGeneration">PCIe Generation</label>
                        <select asp-for="PCIeGeneration" class="form-control">
                            <option value="3">Gen 3</option>
                            <option value="4" selected>Gen 4</option>
                            <option value="5">Gen 5</option>
                        </select>
                    </div>

                    <!-- PCIe Lanes -->
                    <div class="form-group">
                        <label class="form-label" asp-for="PCIeLanes">PCIe Lanes</label>
                        <select asp-for="PCIeLanes" class="form-control">
                            <option value="4">x4</option>
                            <option value="8">x8</option>
                            <option value="16" selected>x16</option>
                        </select>
                    </div>

                    <!-- Display Outputs -->
                    <div class="form-group">
                        <label class="form-label" asp-for="DisplayOutputs">Display Outputs</label>
                        <input asp-for="DisplayOutputs" class="form-control" placeholder="3x DP 1.4a, 1x HDMI 2.1" />
                    </div>

                    <!-- Price -->
                    <div class="form-group">
                        <label class="form-label" asp-for="Price">MSRP Price ($) *</label>
                        <input asp-for="Price" type="number" step="0.01" class="form-control" placeholder="699.00" />
                        <span asp-validation-for="Price" class="validation-msg"></span>
                    </div>

                    <!-- Is On Sale -->
                    <div class="form-group" style="justify-content:flex-end">
                        <label class="form-label">Sale Options</label>
                        <div class="form-check-inline">
                            <input asp-for="IsOnSale" type="checkbox" id="IsOnSale" />
                            <label for="IsOnSale">Mark as On Sale</label>
                        </div>
                    </div>

                    <!-- Sale Price (conditional) -->
                    <div class="form-group" id="sale-price-group" style="display:none">
                        <label class="form-label" asp-for="SalePrice">Sale Price ($)</label>
                        <input asp-for="SalePrice" type="number" step="0.01" class="form-control" placeholder="549.00" />
                    </div>

                    <!-- Image URL -->
                    <div class="form-group full">
                        <label class="form-label" asp-for="ImageUrl">Image URL (optional)</label>
                        <input asp-for="ImageUrl" class="form-control" placeholder="https://..." />
                    </div>

                    <!-- Description -->
                    <div class="form-group full">
                        <label class="form-label" asp-for="Description">Description</label>
                        <textarea asp-for="Description" class="form-control" placeholder="Brief product description..."></textarea>
                    </div>

                    <!-- Checkboxes -->
                    <div class="form-group">
                        <label class="form-label">Features</label>
                        <div class="form-check-inline">
                            <input asp-for="RayTracingSupport" type="checkbox" />
                            <label asp-for="RayTracingSupport">Ray Tracing Support</label>
                        </div>
                    </div>
                    <div class="form-group" style="justify-content:flex-end;padding-top:22px">
                        <div class="form-check-inline">
                            <input asp-for="DLSSSupport" type="checkbox" />
                            <label asp-for="DLSSSupport">DLSS / FSR / XeSS Support</label>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Availability</label>
                        <div class="form-check-inline">
                            <input asp-for="InStock" type="checkbox" checked />
                            <label asp-for="InStock">In Stock</label>
                        </div>
                    </div>
                </div>

            </div>
            <div class="form-footer">
                <button type="submit" class="admin-btn btn-primary">⊕ Add GPU to Inventory</button>
                <a href="/Admin" class="admin-btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    // Sale price toggle handled by site.js
</script>
}
